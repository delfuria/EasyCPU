<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="EasyCPU.Views.MessageBoxWindow"
        Title="EasyCPU"
        Width="360" Height="140"
        CanResize="False"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner">
    <StackPanel Margin="20" Spacing="16" VerticalAlignment="Center">
        <TextBlock Name="MessageText" TextWrapping="Wrap"/>
        <Button Content="OK" Click="OnOk" MinWidth="85" HorizontalAlignment="Center" HorizontalContentAlignment="Center" IsDefault="True"/>
    </StackPanel>
</Window>

<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:EasyCPU.ViewModels"
        xmlns:views="clr-namespace:EasyCPU.Views"
        x:Class="EasyCPU.Views.OpzioniWindow"
        x:CompileBindings="False"
        Title="Opzioni"
        Width="460" Height="520"
        CanResize="False"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner">
    <DockPanel Margin="16">

        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8" Margin="0,12,0,0">
            <Button Content="OK"      Click="OnOk"      IsDefault="True" MinWidth="75"/>
            <Button Content="Annulla" Click="OnAnnulla" IsCancel="True"  MinWidth="75"/>
        </StackPanel>

        <views:OpzioniView/>
    </DockPanel>
</Window>

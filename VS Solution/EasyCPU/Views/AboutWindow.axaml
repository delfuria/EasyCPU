<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:EasyCPU.Views"
        x:Class="EasyCPU.Views.AboutWindow"
        Title="Informazioni su EasyCPU"
        Width="360" SizeToContent="Height"
        CanResize="False"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner">
    <DockPanel>
        <Button DockPanel.Dock="Bottom" Content="OK" Click="OnOk" MinWidth="85"
                HorizontalAlignment="Center" HorizontalContentAlignment="Center" IsDefault="True" Margin="0,0,0,16"/>
        <views:AboutView/>
    </DockPanel>
</Window>
